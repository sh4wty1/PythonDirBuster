# Optional environment variables for the Vercel deployment (api/index.py).
#
# The serverless scan is open to any domain, so no allow-list var is required.
# These only tune how much work each scan does so it fits the function timeout
# (vercel.json sets maxDuration to 60s). Leave them unset to use the defaults.

# How many wordlist entries to probe (top-N of the frequency-ordered list).
# 12k reaches deep admin-panel paths (/boss, /controlpanel, /adminpanel).
MAX_WORDS=12000

# Max concurrent requests. Higher finishes the bigger list faster.
MAX_THREADS=100

# Wall-clock budget (seconds) per scan. The scan stops and returns partial
# results before Vercel's 60s hard limit kills the function. Slow or
# rate-limiting targets simply get as far as this allows.
SCAN_BUDGET=48
